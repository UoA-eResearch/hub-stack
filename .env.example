# Copy this file to .env, then fill it in with credentials.
# research-hub-web variables
BROWSERSTACK_CREDENTIALS_USER=
BROWSERSTACK_CREDENTIALS_KEY=

# cer-graphql variables
AWS_PROFILE=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_SPACE_ID=
COGNITO_REGION=
COGNITO_USER_POOL=

// 2FAB Lambda endpoint vars. The lambda used to retrieve OAUTH tokens for integration tests.
// You can copy these straight into your regular .env file.
OAUTH_LAMBDA_HOST = "ef54vsv71a.execute-api.ap-southeast-2.amazonaws.com"   // the base endpoint for 2FAB Lambda function. e.g. <alphaNumeric>.execute-api.<region>.amazonaws.com
OAUTH_LAMBDA_PATH = "/sandbox/"  // the slug for the endpoint that follows the host e.g. "/<something>/"
OAUTH_LAMBDA_REGION = "ap-southeast-2" // amazon region that 2FAB is run in
OAUTH_LAMBDA_SERVICE = "execute-api"  "execute-api" // shouldn't vary.